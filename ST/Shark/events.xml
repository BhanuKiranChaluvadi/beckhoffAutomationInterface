<EventClasses>
	<!--
	  Event Classes are TwinCAT project config items (SYSTEM, Type System, Event Classes),
	  not IEC 61131-3 source, so they're synced from this manifest the same way
	  libraries.xml/io-devices.xml are synced, not parsed from .st files.

	  Guid is the Event Class's own identity (referenced by name in ST as
	  "<EventClassName>.<EventName>"). This is NOT a freshly-generated GUID: it's the
	  real GUID from a working reference project (see
	  ST/Shark/event-classes/BeckhoffLibEvents.xml). A freshly invented GUID would not
	  match the actual DataType written to the .tsproj (see
	  Sync/TsprojEventClassEditor.cs), so this field documents what's really in the
	  project rather than a value you're free to regenerate.
	-->
	<EventClass Name="BeckhoffLibEvents" Guid="{70AB1C3F-056A-429D-8212-5E248E2724AB}">
		<Event Name="Verbose"  Id="1" Severity="Verbose"  Message="{0} - {1}" />
		<Event Name="Info"     Id="2" Severity="Info"     Message="{0} - {1}" />
		<Event Name="Warning"  Id="3" Severity="Warning"  Message="{0} - {1}" />
		<Event Name="Error"    Id="4" Severity="Error"    Message="{0} - {1}" />
		<Event Name="Critical" Id="5" Severity="Critical" Message="{0} - {1}" />
	</EventClass>
</EventClasses>
